# Node.js
NODE_ENV=production
PORT=3000

# Database - Será preenchido pelo Railway
DB_HOST=${DB_HOST}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_NAME=ecommerce
DB_PORT=3306

# JWT
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRE=7d

# CORS - Adicione seus domínios aqui
ALLOWED_ORIGINS=https://seu-frontend.com,http://localhost:5173,http://localhost:3000

# Logs
LOG_LEVEL=info

# Backup
MYSQLDUMP_PATH=/usr/bin/mysqldump

# Segurança
BCRYPT_SALT_ROUNDS=10
