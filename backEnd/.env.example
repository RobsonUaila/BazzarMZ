# --- CONFIGURAÇÃO DO SERVIDOR ---
# development, production, test
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://seu-dominio.com

# --- BANCO DE DADOS ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=ecommerce
# Limite de conexões simultâneas
DB_CONNECTION_LIMIT=10
# Caminho para o executável do mysqldump (necessário se não estiver no PATH global)
# Exemplo Windows (XAMPP): C:/xampp/mysql/bin/mysqldump.exe
MYSQLDUMP_PATH=mysqldump

# --- SEGURANÇA (JWT) ---
# Gere uma chave forte (min 32 chars) para produção: openssl rand -base64 32
JWT_SECRET=segredo_super_secreto_dev_apenas
JWT_EXPIRE=30d
BCRYPT_SALT_ROUNDS=10

# --- LOGS E MONITORAMENTO ---
# fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- UPLOADS ---
# Limite de tamanho para upload (ex: 5mb)
MAX_FILE_SIZE=5242880